{% block order_item_widget %}
    {% import 'components/collection_type.macro.html.twig' as collection %}
    {% set item = form.vars.data %}
    <tr class="collection-item table-primary">
        <td style="min-width: 200px">
            {{ form_widget(form.part) }}
            {% if item is not null and item.part is not null %}
                {% set part_description = item.part.description|striptags|trim %}
                {% if part_description is not empty %}
                    <div class="small text-muted mt-1">
                        {{ part_description|slice(0, 80) }}{% if part_description|length > 80 %}…{% endif %}
                    </div>
                {% endif %}
            {% endif %}
        </td>
        <td class="text-center">
            {% if item is not null and item.part is not null %}
                <a href="{{ entity_url(item.part, 'info') }}" target="_blank"
                   data-turbo="false" rel="noopener"
                   title="{% trans %}order.item.open_part{% endtrans %}">
                    <i class="fa-solid fa-up-right-from-square fa-fw"></i>
                </a>
            {% endif %}
        </td>
        <td>{{ form_widget(form.quantity, {'attr': {'style': 'width:100px'}}) }}</td>
        <td style="min-width: 150px">{{ form_widget(form.supplier) }}</td>
        <td style="min-width: 120px">{{ form_widget(form.supplierPartNr) }}</td>
        <td>
            <button type="button" class="btn btn-sm btn-outline-danger" {{ collection.delete_btn() }}>
                <i class="fa-solid fa-times fa-fw"></i>
            </button>
        </td>
    </tr>
{% endblock %}
