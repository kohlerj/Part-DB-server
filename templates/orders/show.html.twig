{% extends "main_card.html.twig" %}
{% import 'components/collection_type.macro.html.twig' as collection %}

{% block title %}{% trans %}order.show.title{% endtrans %}: {{ order.name }}{% endblock %}

{% block card_title %}
    <i class="fa-solid fa-cart-shopping fa-fw"></i>
    {% trans %}order.show.title{% endtrans %}: <b>{{ order.name }}</b>
{% endblock %}

{% block card_content %}
    {# Action bar #}
    <div class="mb-3 d-flex gap-2 flex-wrap">
        {% if is_granted('read', order) %}
            <a href="{{ path('order_export_csv', {'id': order.id}) }}" data-turbo="false" class="btn btn-sm btn-outline-secondary">
                <i class="fa-solid fa-file-csv fa-fw"></i>
                {% trans %}order.export_csv{% endtrans %}
            </a>
        {% endif %}
        {% if is_granted('receive', order) %}
            <a href="{{ path('order_receive', {'id': order.id}) }}" class="btn btn-sm btn-outline-success">
                <i class="fa-solid fa-boxes-packing fa-fw"></i>
                {% trans %}order.receive.button{% endtrans %}
            </a>
        {% endif %}
        {% if is_granted('delete', order) %}
            <button type="button" class="btn btn-sm btn-outline-danger ms-auto"
                    data-bs-toggle="modal" data-bs-target="#deleteModal">
                <i class="fa-solid fa-trash fa-fw"></i>
                {% trans %}delete{% endtrans %}
            </button>
        {% endif %}
    </div>

    {{ form_start(form) }}

    {# Metadata section #}
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            {{ form_row(form.name) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.notes) }}
        </div>
    </div>

    {# Supplier references #}
    <h5><i class="fa-solid fa-hashtag fa-fw"></i> {% trans %}order.supplier_references{% endtrans %}</h5>
    <div {{ collection.controller(form.supplierReferences) }}>
        <div {{ collection.target() }}>
            {% for refForm in form.supplierReferences %}
                <div class="row g-2 align-items-center mb-2 collection-item">
                    <div class="col-md-4">{{ form_row(refForm.supplier) }}</div>
                    <div class="col-md-6">{{ form_row(refForm.orderNumber) }}</div>
                    <div class="col-md-2">
                        <button type="button" class="btn btn-sm btn-outline-danger" {{ collection.delete_btn() }}>
                            <i class="fa-solid fa-times fa-fw"></i>
                        </button>
                    </div>
                </div>
            {% endfor %}
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary mb-2" {{ collection.create_btn() }}>
            <i class="fa-solid fa-plus fa-fw"></i>
            {% trans %}order.supplier_reference.add{% endtrans %}
        </button>
    </div>

    <hr>

    {# Add the order_item_widget block so the prototype for new items renders as a proper <tr> row.
       Note: no "only" keyword, so the global form themes (TomSelect, part select, etc.) still apply. #}
    {% form_theme form.items with ['form/order_item_layout.html.twig'] %}

    {# Items table #}
    <h5><i class="fa-solid fa-list fa-fw"></i> {% trans %}order.items{% endtrans %}
        <span class="badge bg-secondary">{{ order.items | length }}</span>
    </h5>

    <div {{ collection.controller(form.items) }}>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle" id="order-items-table" {{ collection.target() }}>
                <thead class="table-light">
                    <tr>
                        <th class="text-nowrap">{% trans %}order.item.name{% endtrans %}</th>
                        <th></th>
                        <th class="text-nowrap">{% trans %}order.item.quantity{% endtrans %}</th>
                        <th class="text-nowrap">{% trans %}order.item.supplier{% endtrans %}</th>
                        <th class="text-nowrap">{% trans %}order.item.supplier_part_nr{% endtrans %}</th>
                        {% if is_granted('edit', order) %}<th></th>{% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for itemForm in form.items %}
                        <tr class="collection-item{% if itemForm.vars.data.id is null %} table-primary{% endif %}">
                            <td style="min-width: 200px">
                                {{ form_widget(itemForm.part) }}
                                {% if itemForm.vars.data.part is not null %}
                                    {% set part_description = itemForm.vars.data.part.description|striptags|trim %}
                                    {% if part_description is not empty %}
                                        <div class="small text-muted mt-1">
                                            {{ part_description|slice(0, 80) }}{% if part_description|length > 80 %}…{% endif %}
                                        </div>
                                    {% endif %}
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if itemForm.vars.data.part is not null %}
                                    <a href="{{ entity_url(itemForm.vars.data.part, 'info') }}" target="_blank"
                                       data-turbo="false" rel="noopener"
                                       title="{% trans %}order.item.open_part{% endtrans %}">
                                        <i class="fa-solid fa-up-right-from-square fa-fw"></i>
                                    </a>
                                {% endif %}
                            </td>
                            <td>{{ form_widget(itemForm.quantity, {'attr': {'style': 'width:100px'}}) }}</td>
                            <td style="min-width: 150px">{{ form_widget(itemForm.supplier) }}</td>
                            <td style="min-width: 120px">{{ form_widget(itemForm.supplierPartNr) }}</td>
                            {% if is_granted('edit', order) %}
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger" {{ collection.delete_btn() }}>
                                        <i class="fa-solid fa-times fa-fw"></i>
                                    </button>
                                </td>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if is_granted('edit', order) %}
            <button type="button" class="btn btn-sm btn-outline-secondary mb-3" {{ collection.create_btn() }}>
                <i class="fa-solid fa-plus fa-fw"></i>
                {% trans %}order.item.add{% endtrans %}
            </button>
        {% endif %}
    </div>

    {% if is_granted('edit', order) %}
        <div class="mt-3">
            {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary'}}) }}
            <a href="{{ path('order_list') }}" class="btn btn-secondary ms-2">{% trans %}cancel{% endtrans %}</a>
        </div>
    {% endif %}

    {{ form_end(form) }}

    {# Delete modal #}
    {% if is_granted('delete', order) %}
        <div class="modal fade" id="deleteModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">{% trans %}order.delete.confirm.title{% endtrans %}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        {% trans with {'%name%': order.name} %}order.delete.confirm.message{% endtrans %}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{% trans %}cancel{% endtrans %}</button>
                        <form method="post" action="{{ path('order_delete', {'id': order.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_order_' ~ order.id) }}">
                            <button type="submit" class="btn btn-danger">{% trans %}delete{% endtrans %}</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    <script nonce="{{ csp_nonce('script') }}">
        (function () {
            const container = document.getElementById('order-items-table');
            if (!container) {
                return;
            }
            const baseUrl = {{ path('order_part_orderdetails')|json_encode|raw }};
            const skuMissingPlaceholder = {{ 'order.item.sku_missing'|trans|json_encode|raw }};
            const cache = {};

            function rowOf(el) {
                return el.closest('tr.collection-item');
            }

            function partSelectOf(row) {
                return row.querySelector("select[data-controller~='elements--part-select']");
            }

            function partIdOf(row) {
                const ps = partSelectOf(row);
                if (!ps) {
                    return '';
                }
                return ps.tomselect ? ps.tomselect.getValue() : ps.value;
            }

            function fetchOrderdetails(partId) {
                if (cache[partId]) {
                    return Promise.resolve(cache[partId]);
                }
                const url = baseUrl + '?part=' + encodeURIComponent(partId);
                return fetch(url, {headers: {'Accept': 'application/json'}})
                    .then(r => r.ok ? r.json() : [])
                    .then(data => {
                        cache[partId] = Array.isArray(data) ? data : [];
                        return cache[partId];
                    })
                    .catch(() => []);
            }

            function uniqueSuppliers(ods) {
                const seen = new Set();
                const out = [];
                ods.forEach(od => {
                    if (od.supplier_id === null || od.supplier_id === undefined) {
                        return;
                    }
                    const key = String(od.supplier_id);
                    if (seen.has(key)) {
                        return;
                    }
                    seen.add(key);
                    out.push({id: key, name: od.supplier_name || ''});
                });
                return out;
            }

            function supplierValueOf(select) {
                if (!select) {
                    return '';
                }
                // When TomSelect manages the select, its value is the source of truth
                return select.tomselect ? select.tomselect.getValue() : select.value;
            }

            function supplierTextOf(select) {
                const ts = select.tomselect;
                if (ts) {
                    const val = ts.getValue();
                    const opt = val ? ts.options[val] : null;
                    return opt ? (opt.text || '') : '';
                }
                const opt = select.options[select.selectedIndex];
                return opt ? opt.textContent : '';
            }

            function populateSuppliers(row, ods, keepSelection) {
                const select = row.querySelector('.js-order-item-supplier');
                if (!select) {
                    return;
                }
                const ts = select.tomselect;
                const previous = supplierValueOf(select);
                const previousText = supplierTextOf(select);
                const suppliers = uniqueSuppliers(ods);

                // Build the desired list of options ([value, text])
                const options = [{value: '', text: ''}];
                const included = new Set();
                suppliers.forEach(s => {
                    options.push({value: s.id, text: s.name});
                    included.add(s.id);
                });

                // Preserve a previously saved supplier even if it is not among the part's order details
                if (keepSelection && previous && !included.has(previous)) {
                    options.push({value: previous, text: previousText});
                    included.add(previous);
                }

                let value = '';
                if (keepSelection && previous && included.has(previous)) {
                    value = previous;
                } else if (suppliers.length > 0) {
                    value = suppliers[0].id;
                }

                if (ts) {
                    // Drive TomSelect through its API so the dropdown and the
                    // underlying <select> value stay in sync.
                    ts.clear(true);
                    ts.clearOptions(() => false);
                    options.forEach(o => ts.addOption({value: o.value, text: o.text}));
                    ts.refreshOptions(false);
                    ts.setValue(value, true);
                } else {
                    select.innerHTML = '';
                    options.forEach(o => {
                        const opt = document.createElement('option');
                        opt.value = o.value;
                        opt.textContent = o.text;
                        select.appendChild(opt);
                    });
                    select.value = value;
                }
            }

            function updateSku(row) {
                const skuInput = row.querySelector('.js-order-item-sku');
                const select = row.querySelector('.js-order-item-supplier');
                if (!skuInput) {
                    return;
                }
                const ods = cache[partIdOf(row)] || [];
                const sid = supplierValueOf(select);
                let sku = '';
                if (sid) {
                    const match = ods.find(od => String(od.supplier_id) === String(sid));
                    if (match) {
                        sku = match.sku || '';
                    }
                }
                skuInput.value = sku;
                // Show a greyed-out placeholder when a supplier is selected but no SKU is available
                skuInput.placeholder = (sid && !sku) ? skuMissingPlaceholder : '';
            }

            function onPartChange(row) {
                const partId = partIdOf(row);
                if (!partId) {
                    populateSuppliers(row, [], false);
                    updateSku(row);
                    return;
                }
                fetchOrderdetails(partId).then(ods => {
                    populateSuppliers(row, ods, false);
                    updateSku(row);
                });
            }

            function initRow(row) {
                const partId = partIdOf(row);
                if (!partId) {
                    return;
                }
                const skuInput = row.querySelector('.js-order-item-sku');
                const skuWasEmpty = skuInput ? skuInput.value.trim() === '' : false;
                fetchOrderdetails(partId).then(ods => {
                    // On load keep a saved supplier; only derive the SKU when none was saved
                    populateSuppliers(row, ods, true);
                    if (skuWasEmpty) {
                        updateSku(row);
                    }
                });
            }

            container.addEventListener('change', function (e) {
                const row = rowOf(e.target);
                if (!row) {
                    return;
                }
                if (e.target.matches("select[data-controller~='elements--part-select']")) {
                    onPartChange(row);
                } else if (e.target.matches('.js-order-item-supplier')) {
                    updateSku(row);
                }
            });

            container.querySelectorAll('tr.collection-item').forEach(initRow);
        })();
    </script>
{% endblock %}
